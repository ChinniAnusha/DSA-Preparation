class Solution:
    def eraseOverlapIntervals(self, intervals: List[List[int]]) -> int:
         intervals.sort(key = lambda x:x[1])
         count = 0
         last_time = intervals[0][1]
         n = len(intervals)
         for i in range(1,n):
            if intervals[i][0] < last_time:
                count += 1 
            else:
                last_time = intervals[i][1]
         return count
