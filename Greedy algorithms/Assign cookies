class Solution:
    def findContentChildren(self, g: List[int], s: List[int]) -> int:
        if not s:
            return 0
        g.sort()
        s.sort()
        n = len(g)
        m = len(s)
        l,r = 0,0
        while l < m and r < n:
            if g[r] <= s[l]:
                r += 1
            l += 1
        return r
#TC:O(nlogn+mlogm+m+n)
#SC:O(1)
