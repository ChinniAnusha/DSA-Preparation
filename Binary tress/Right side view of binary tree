# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution:
    def check(self,root,res,level):
        if root is None:
            return res
        if level == len(res):
            res.append(root.val)
        self.check(root.right,res,level+1)
        self.check(root.left,res,level+1)

    def rightSideView(self, root: Optional[TreeNode]) -> List[int]:
         res = []
         level = 0
         self.check(root,res,level)
         return res
#TC:O(n)
#SC:O(h) where h is the height of the tree
