class Solution:
    def inorder(self,node):
        if node is None:
            return None
        
        self.inorder(node.left)
        
        self.k -= 1
        if self.k == 0:
            self.result = node.val
            return
        self.inorder(node.right)
        
    def kthSmallest(self, root: Optional[TreeNode], k: int) -> int:
         self.k = k
         self.result = None
         self.inorder(root)
         return self.result
#TC:O(n)
#SC:O(h)
