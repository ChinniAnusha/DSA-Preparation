class BSTIterator:

    def __init__(self, root: Optional[TreeNode]):
        self.stack = []
        self.pushall(root)

    def next(self) -> int:
        node = self.stack.pop()
        self.pushall(node.right)
        return node.val

    def hasNext(self) -> bool:
        return len(self.stack) > 0

    def pushall(self,node):
        while node:
            self.stack.append(node)
            node = node.left
